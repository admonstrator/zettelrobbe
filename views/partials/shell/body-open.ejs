<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : 'h-full' %>">
    <div class="layout-container">
        <button id="mobileMenuToggle" type="button" class="mobile-menu-toggle" aria-label="Open navigation" aria-controls="appSidebar" aria-expanded="false">
            <i class="fas fa-bars" aria-hidden="true"></i>
        </button>

        <button id="sidebarOverlay" type="button" class="sidebar-overlay" aria-label="Close navigation"></button>

        <aside id="appSidebar" class="sidebar" aria-hidden="false">
            <div class="sidebar-header">
                <img src="/logo.png" class="no-invert" alt="Zettelrobbe Logo" style="height: 60px;">
                <h1 class="brand-title">Zettelrobbe<small class="sidebar-version" title="<%= typeof version !== 'undefined' ? version : '' %>"><%= typeof version !== 'undefined' ? version : '' %></small></h1>
            </div>

            <nav class="sidebar-nav">
                <%- include('../sidebar-nav', {
                    chatEnabled: typeof chatEnabled !== 'undefined' ? chatEnabled : false
                }) %>
            </nav>
        </aside>

        <main class="<%= typeof mainClass !== 'undefined' ? mainClass : 'main-content' %>">
        <%- include('../changelog-modal') %>
