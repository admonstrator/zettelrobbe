{
  "name": "paperless-ai-next",
  "version": "1.0.0",
  "description": "AI based Tag, correspondent and meta data generation",
  "main": "server.js",
  "scripts": {
    "test": "nodemon server.js",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test:all": "node scripts/run-tests.js --all",
    "test:area:auth": "node scripts/run-tests.js --area auth",
    "test:area:ocr": "node scripts/run-tests.js --area ocr",
    "test:area:observability": "node scripts/run-tests.js --area observability",
    "test:area:processing": "node scripts/run-tests.js --area processing",
    "test:area:prompts": "node scripts/run-tests.js --area prompts",
    "test:area:quickstart": "node scripts/run-tests.js --area quickstart",
    "test:document-type-restriction": "node scripts/run-tests.js --test document-type-restriction",
    "test:effective-document-count-cache": "node scripts/run-tests.js --test effective-document-count-cache",
    "test:failed-reset-all": "node scripts/run-tests.js --test failed-reset-all",
    "test:ignore-tags-filter": "node scripts/run-tests.js --test ignore-tags-filter",
    "test:log-level-config": "node scripts/run-tests.js --test log-level-config",
    "test:log-level-logger": "node scripts/run-tests.js --test log-level-logger",
    "test:login-mfa-flow": "node scripts/run-tests.js --test login-mfa-flow",
    "test:ocr-fallback-ai-errors": "node scripts/run-tests.js --test ocr-fallback-ai-errors",
    "test:ocr-startup-recovery": "node scripts/run-tests.js --test ocr-startup-recovery",
    "test:pr772-fix": "node scripts/run-tests.js --test pr772-fix",
    "test:rate-limiting": "node scripts/run-tests.js --test rate-limiting",
    "test:scan-stop-flow": "node scripts/run-tests.js --test scan-stop-flow",
    "test:setup-remote-guard": "node scripts/run-tests.js --test setup-remote-guard",
    "test:area:security": "node scripts/run-tests.js --area security",
    "test:restriction-service": "node scripts/run-tests.js --test restriction-service",
    "test:updated-service": "node scripts/run-tests.js --test updated-service",
    "test:list": "node scripts/run-tests.js --list",
    "mfa:reset": "node scripts/mfa-reset.js"
  },
  "keywords": [
    "paperless-ngx",
    "ai",
    "paperless",
    "artificial",
    "intelligence"
  ],
  "nodemonConfig": {
    "ignore": [
      "test/*",
      "node_modules/*",
      ".git/*",
      "*.log",
      "public/*",
      "views/*",
      "document.json",
      "OPENAPI/openapi.json"
    ]
  },
  "author": "admonstrator",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.6.0",
    "openai": "^6.47.0",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tiktoken": "^1.0.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jsdoc": "^63.2.0",
    "globals": "^17.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.9.5"
  },
  "allowScripts": {
    "better-sqlite3": true,
    "@scarf/scarf": false
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "better-sqlite3"
    ]
  }
}
